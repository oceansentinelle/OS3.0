# ============================================================================
# Ocean Sentinel V3.0 - Configuration Complète
# ============================================================================
# IMPORTANT: Copiez ce fichier vers .env et modifiez les valeurs
# Commande: cp .env.full.example .env
# ============================================================================

# ============================================================================
# Database (TimescaleDB)
# ============================================================================

POSTGRES_DB=oceansentinel
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_now

# Port externe
POSTGRES_PORT=5432

# Connexion depuis application
DB_HOST=postgres
DB_PORT=5432
DB_NAME=oceansentinel
DB_USER=admin
DB_PASSWORD=change_me_now

# ============================================================================
# Redis
# ============================================================================

REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# MinIO (Stockage objets)
# ============================================================================

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_now_too
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================================
# API
# ============================================================================

API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_secret_key

# ============================================================================
# Logging
# ============================================================================

LOG_LEVEL=INFO

# ============================================================================
# Phase 1 - MVP Sources
# ============================================================================

# ERDDAP COAST-HF
ENABLE_ERDDAP_COAST_HF=true
ERDDAP_COAST_HF_INTERVAL_MINUTES=60

# ERDDAP SOMLIT
ENABLE_ERDDAP_SOMLIT=true
ERDDAP_SOMLIT_INTERVAL_MINUTES=360

# Hub'Eau
ENABLE_HUBEAU=true
HUBEAU_INTERVAL_MINUTES=360

# SEANOE Loader (batch historique)
ENABLE_SEANOE_LOADER=false
SEANOE_LOADER_INTERVAL_MINUTES=1440
SEANOE_DATA_DIR=./data/seanoe

# SIBA Enki Loader (data_drop)
ENABLE_SIBA_LOADER=true
SIBA_LOADER_INTERVAL_MINUTES=120
SIBA_DATA_DROP_DIR=./data_drop/siba
SIBA_PROCESSED_DIR=./data_drop/siba/processed

# ============================================================================
# Phase 2 - Référentiels
# ============================================================================

# SHOM Reference
ENABLE_SHOM_REFERENCE=true
SHOM_BASE_URL=https://services.data.shom.fr/geonetwork/srv/api
SHOM_DEFAULT_QUERIES=Litto3D Nouvelle-Aquitaine,Arcachon,bathymetrie,maree
SHOM_MAX_RECORDS=50
SHOM_SYNC_INTERVAL_MINUTES=720

# INSEE Geo (référentiel géographique)
ENABLE_INSEE_GEO=true
API_GEO_BASE_URL=https://geo.api.gouv.fr
API_GEO_DEPARTMENTS=33,17
INSEE_GEO_SYNC_INTERVAL_MINUTES=1440

# INSEE Sirene (établissements)
ENABLE_INSEE_SIRENE=false
INSEE_SIRENE_BASE_URL=https://api.insee.fr/api-sirene/3.11
INSEE_SIRENE_API_KEY=
INSEE_TRACKED_SIRENS=
INSEE_TRACKED_SIRETS=
INSEE_SIRENE_SYNC_INTERVAL_MINUTES=1440

# ============================================================================
# Grafana (optionnel - profile monitoring)
# ============================================================================

GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# ============================================================================
# Notes de Sécurité
# ============================================================================
# 1. Ne commitez JAMAIS le fichier .env dans Git
# 2. Utilisez des mots de passe forts (min 16 caractères)
# 3. Générez avec: openssl rand -base64 32
# 4. Changez tous les mots de passe par défaut
# ============================================================================
