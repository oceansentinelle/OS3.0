# ============================================================================
# OCEAN SENTINEL - VARIABLES D'ENVIRONNEMENT
# ============================================================================
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS COMMITTER LE FICHIER .env (déjà dans .gitignore)
# ============================================================================

# ----------------------------------------------------------------------------
# API MÉTÉO-FRANCE
# ----------------------------------------------------------------------------
# Obtenir une clé sur : https://portail-api.meteofrance.fr/
VITE_METEO_FRANCE_API_KEY=

# ----------------------------------------------------------------------------
# API COPERNICUS MARINE SERVICE (CMEMS)
# ----------------------------------------------------------------------------
# Créer un compte sur : https://marine.copernicus.eu/
VITE_COPERNICUS_USERNAME=
VITE_COPERNICUS_PASSWORD=

# ----------------------------------------------------------------------------
# API NOAA (Public - Pas de clé requise)
# ----------------------------------------------------------------------------
# Documentation : https://polar.ncep.noaa.gov/waves/
# Aucune variable nécessaire

# ----------------------------------------------------------------------------
# BACKEND OCEAN SENTINEL
# ----------------------------------------------------------------------------
# URL de l'API backend FastAPI
VITE_API_BASE_URL=https://oceansentinelle.fr/api/v1

# ----------------------------------------------------------------------------
# CONFIGURATION DÉVELOPPEMENT
# ----------------------------------------------------------------------------
# Mode développement (true = données mockées, false = API réelles)
VITE_DEV_MODE=true

# Timeout des requêtes API (millisecondes)
VITE_API_TIMEOUT=10000

# Intervalle de rafraîchissement (millisecondes)
VITE_REFRESH_INTERVAL=300000

# ----------------------------------------------------------------------------
# ANALYTICS (Optionnel)
# ----------------------------------------------------------------------------
# Google Analytics
VITE_GA_TRACKING_ID=

# Matomo
VITE_MATOMO_URL=
VITE_MATOMO_SITE_ID=

# ----------------------------------------------------------------------------
# SENTRY (Monitoring Erreurs - Optionnel)
# ----------------------------------------------------------------------------
VITE_SENTRY_DSN=

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# - Toutes les variables commencent par VITE_ pour être accessibles côté client
# - Les clés API sensibles doivent être stockées côté backend uniquement
# - En production, utiliser des variables d'environnement système
