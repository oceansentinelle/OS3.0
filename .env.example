# =====================================================
# Ocean Sentinel - Configuration TimescaleDB
# =====================================================
# IMPORTANT: Copiez ce fichier vers .env et modifiez
#            les valeurs avant le déploiement
# Commande: cp .env.example .env
# =====================================================

# =====================================================
# AUTHENTIFICATION POSTGRESQL
# =====================================================

# Utilisateur principal (superuser)
POSTGRES_USER=oceansentinel

# ⚠️  OBLIGATOIRE: Mot de passe fort (min 16 caractères)
# Générez-en un avec: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGEZ_MOI_AVEC_UN_MOT_DE_PASSE_FORT

# Nom de la base de données
POSTGRES_DB=oceansentinelle

# =====================================================
# RÉSEAU
# =====================================================

# Port externe (non-standard pour sécurité)
# Recommandé: 6543, 5433, ou autre port > 1024
POSTGRES_PORT=6543

# =====================================================
# OPTIMISATION (Détectée automatiquement)
# =====================================================

# Ces valeurs sont utilisées par timescaledb-tune
# Elles correspondent à votre VPS Hostinger
TS_TUNE_MEMORY=8GB
TS_TUNE_NUM_CPUS=4
TS_TUNE_MAX_CONNS=100
TS_TUNE_MAX_BG_WORKERS=8

# =====================================================
# TÉLÉMÉTRIE
# =====================================================

# Désactiver la télémétrie TimescaleDB
TIMESCALEDB_TELEMETRY=off

# =====================================================
# NOTES DE SÉCURITÉ
# =====================================================
# 1. Ne commitez JAMAIS le fichier .env dans Git
# 2. Utilisez des mots de passe différents pour:
#    - POSTGRES_PASSWORD (superuser)
#    - oceansentinel_readonly (lecture seule)
#    - oceansentinel_writer (écriture)
# 3. Changez les mots de passe par défaut dans:
#    init-scripts/01-init-timescaledb.sql
# =====================================================
