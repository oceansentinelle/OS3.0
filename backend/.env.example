# Configuration Ocean Sentinel API
# Copier ce fichier en .env et remplir avec les vraies valeurs

# URLs des APIs externes
COAST_HF_BASE_URL=https://www.coast-hf.fr/data/api
HUB_EAU_BASE_URL=https://hubeau.eaufrance.fr/api

# Configuration CORS (origines autorisées, séparées par des virgules)
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://oceansentinelle.fr

# Niveau de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Configuration APIs météo (optionnel pour production)
# OPENWEATHER_API_KEY=votre_cle_api_openweather
# METEO_FRANCE_API_KEY=votre_cle_api_meteo_france
